# SSLert environment variables
# Copy to .env and fill in values, then: docker compose up

# Resend API key (https://resend.com/api-keys)
# If unset, alerts are logged to api container stdout instead of emailed.
RESEND_API_KEY=

# Where alerts go
ALERT_EMAIL_TO=admin@example.com

# "From" address on alert emails. Use a domain verified in your Resend account.
ALERT_EMAIL_FROM=sslert@example.com

# Minutes between automatic SSL checks. Default: 60
CHECK_INTERVAL=60

# Optional. If not set, defaults to ./data/sslert.db in the container
DATABASE_PATH=/app/data/sslert.db

# Optional. Defaults to 3000
PORT=3000

# Optional. Host port for the nginx reverse proxy. Defaults to 5173.
# (The api service is internal-only — it is NOT exposed on a host port.
# Talk to it via the proxy at http://localhost:5173/api/* with a bearer
# token, or `docker compose exec api ...` for CLI operations.)
WEB_PORT=5173

# ── Observability & operations ───────────────────────────────────

# Log level for the pino logger. One of: trace, debug, info, warn,
# error, fatal. Default: info.
LOG_LEVEL=info

# Per-IP request rate limit on /api/* (requests per minute). Health
# and metrics endpoints are exempt. Default: 100.
RATE_LIMIT_PER_MINUTE=100

# Audit log retention in days. Rows older than this are pruned by
# the daily retention tick. Default: 90.
AUDIT_LOG_RETENTION_DAYS=90

# Set to 1 in dev to disable bearer-token auth. NEVER set in
# production — the api has no other auth.
# AUTH_DISABLED=
