# CertPulse environment variables
# Copy to .env and fill in values, then: docker compose up

# Resend API key (https://resend.com/api-keys)
# If unset, alerts are logged to api container stdout instead of emailed.
RESEND_API_KEY=

# Where alerts go
ALERT_EMAIL_TO=admin@example.com

# "From" address on alert emails. Use a domain verified in your Resend account.
ALERT_EMAIL_FROM=certpulse@example.com

# Minutes between automatic SSL checks. Default: 60
CHECK_INTERVAL=60

# Optional. If not set, defaults to ./data/certpulse.db in the container
DATABASE_PATH=/app/data/certpulse.db

# Optional. Defaults to 3000
PORT=3000
