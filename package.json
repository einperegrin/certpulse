{
  "name": "sslert",
  "version": "0.4.1",
  "license": "AGPL-3.0",
  "private": true,
  "description": "Self-hosted SSL expiry monitor with email alerts",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev:api": "npm run dev --workspace=@sslert/api",
    "dev:web": "npm run dev --workspace=@sslert/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspace=@sslert/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace=@sslert/api",
    "db:migrate": "npm run db:migrate --workspace=@sslert/api"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1"
  }
}
