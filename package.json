{
  "name": "certpulse",
  "version": "0.4.1",
  "private": true,
  "description": "Self-hosted SSL expiry monitor with email alerts",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev:api": "npm run dev --workspace=@certpulse/api",
    "dev:web": "npm run dev --workspace=@certpulse/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspace=@certpulse/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace=@certpulse/api",
    "db:migrate": "npm run db:migrate --workspace=@certpulse/api"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "vite": "^6.0.0",
    "html-encoding-sniffer": "^4.0.0",
    "jsdom": "^26.1.0"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0"
  }
}
