{
  "name": "@certpulse/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "token:create": "tsx src/cli/tokens.ts create",
    "token:list": "tsx src/cli/tokens.ts list",
    "token:revoke": "tsx src/cli/tokens.ts revoke"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.5",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^0.19.10",
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.10",
    "node-cron": "^3.0.3",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^11.2.0",
    "resend": "^4.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
